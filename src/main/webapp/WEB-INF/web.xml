<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <!--
        web.xml 역할
        ------------------------------------------------------------------
        1) WAS(Tomcat)가 웹 애플리케이션 시작 시 가장 먼저 읽는 설정 파일
        2) Spring 의 DispatcherServlet 을 등록
        3) 모든 *.do 요청을 Spring MVC 로 보냄

        흐름
        브라우저 -> *.do 요청 -> DispatcherServlet -> @Controller
    -->

    <display-name>mig-progress</display-name>

    <!--
        DispatcherServlet
        ------------------------------------------------------------------
        Spring MVC 의 프론트 컨트롤러다.
        모든 요청을 먼저 받고,
        어떤 Controller 메서드로 보낼지 찾아준다.
    -->
    <servlet>
        <servlet-name>mig-dispatcher</servlet-name>
        <servlet-class>org.springframework.web.servlet.DispatcherServlet</servlet-class>

        <!--
            contextConfigLocation
            ------------------------------------------------------------------
            DispatcherServlet 이 읽을 Spring MVC 설정 파일 경로
        -->
        <init-param>
            <param-name>contextConfigLocation</param-name>
            <param-value>/WEB-INF/spring/mig-dispatcher-servlet.xml</param-value>
        </init-param>

        <!-- 서버 시작 시 서블릿 미리 로딩 -->
        <load-on-startup>1</load-on-startup>
    </servlet>

    <!--
        *.do 패턴으로 요청 매핑
        예:
        /mig/progress/view.do
        /mig/progress/all.do
    -->
    <servlet-mapping>
        <servlet-name>mig-dispatcher</servlet-name>
        <url-pattern>*.do</url-pattern>
    </servlet-mapping>

    <!-- 한글 깨짐 방지용 인코딩 필터 -->
    <filter>
        <filter-name>encodingFilter</filter-name>
        <filter-class>org.springframework.web.filter.CharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
        <init-param>
            <param-name>forceEncoding</param-name>
            <param-value>true</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>encodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 기본 진입점 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
