<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:context="http://www.springframework.org/schema/context"
       xmlns:mvc="http://www.springframework.org/schema/mvc"
       xsi:schemaLocation="
           http://www.springframework.org/schema/beans https://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context https://www.springframework.org/schema/context/spring-context.xsd
           http://www.springframework.org/schema/mvc https://www.springframework.org/schema/mvc/spring-mvc.xsd">

    <!--
        이 파일 역할
        ------------------------------------------------------------------
        1) @Controller / @Service / @Repository 스캔
        2) @RequestMapping, @ResponseBody 같은 MVC 어노테이션 활성화
        3) JSP View Resolver 설정
        4) 정적 리소스(css/js) 접근 허용
    -->

    <!-- 지정 패키지 하위의 어노테이션 빈 자동 등록 -->
    <context:component-scan base-package="mig.progress" />

    <!--
        mvc:annotation-driven
        ------------------------------------------------------------------
        @RequestMapping
        @ResponseBody
        Jackson JSON 변환기
        등을 활성화한다.
    -->
    <mvc:annotation-driven />

    <!--
        resources 매핑
        ------------------------------------------------------------------
        /resources/** 요청이 오면 src/main/webapp/resources 아래 파일을 그대로 응답
    -->
    <mvc:resources mapping="/resources/**" location="/resources/" />

    <!--
        JSP View Resolver
        ------------------------------------------------------------------
        Controller 가 문자열 "migProgress" 를 반환하면
        실제로는 /WEB-INF/views/migProgress.jsp 로 연결된다.
    -->
    <bean class="org.springframework.web.servlet.view.InternalResourceViewResolver">
        <property name="prefix" value="/WEB-INF/views/" />
        <property name="suffix" value=".jsp" />
    </bean>
</beans>
